{
  "name": "alpu-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "vite dev",
    "build": "graphql-codegen && vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint src",
    "fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "generate": "graphql-codegen",
    "generate:watch": "graphql-codegen --watch"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/fira-mono": "latest",
    "@graphql-codegen/cli": "^7.0.0",
    "@graphql-codegen/client-preset": "^6.0.0",
    "@graphql-codegen/typescript": "^6.0.1",
    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^1.17.0",
    "@neoconfetti/svelte": "latest",
    "@parcel/watcher": "^2.5.6",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/table-core": "^8.21.3",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "bits-ui": "^2.17.3",
    "clsx": "^2.1.1",
    "eslint": "^10.2.1",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.1",
    "layerchart": "2.0.0-next.48",
    "mode-watcher": "^1.1.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-svelte": "^3.5.1",
    "shadcn-svelte": "^1.2.7",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "svelte-eslint-parser": "^1.6.0",
    "svelte-sonner": "^1.1.1",
    "svelte2tsx": "^0.7.55",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.7"
  },
  "dependencies": {
    "@urql/core": "^6.0.1",
    "@urql/svelte": "^5.0.0",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "graphql-ws": "^6.0.8",
    "lucide-svelte": "^1.0.1"
  }
}
